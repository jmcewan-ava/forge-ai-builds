# ─── REQUIRED ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── GITHUB (required for file writer) ──────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-target-repo
GITHUB_WEBHOOK_SECRET=a-random-secret-string

# ─── SEED PROTECTION ─────────────────────────────────────────────────────────
SEED_KEY=another-random-secret

# ─── TUNING (optional — defaults shown) ──────────────────────────────────────
MAX_QA_ITERATIONS=3
MAX_PARALLEL_AGENTS=5
SESSION_COST_LIMIT_USD=10.00
TOTAL_COST_LIMIT_USD=100.00
OFFICE_MANAGER_MODEL=claude-opus-4-6
BUILDER_MODEL=claude-sonnet-4-6
QA_MODEL=claude-sonnet-4-6
